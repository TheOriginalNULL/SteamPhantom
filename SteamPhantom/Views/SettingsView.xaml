<UserControl x:Class="SteamPhantom.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SteamPhantom.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="36,24,36,16" MaxWidth="760" HorizontalAlignment="Left">

                <!-- Page title -->
                <TextBlock Text="Settings" FontSize="26" FontWeight="SemiBold"/>
                <TextBlock Margin="0,4,0,0"
                           Foreground="{StaticResource SubtleForegroundBrush}"
                           Text="How SteamPhantom signs in, talks to Steam, and looks."/>

                <!-- ACCOUNT -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="ACCOUNT"/>
                <Border Style="{StaticResource SettingsCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Signed-out -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSignedIn}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Not signed in" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="Sign in with Steam credentials to load your library without an API key. Token is encrypted on this machine."
                                       FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"
                                       Foreground="{StaticResource SubtleForegroundBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Sign in" Command="{Binding SignInCommand}"
                                VerticalAlignment="Center" MinWidth="120">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSignedIn}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Signed-in -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSignedIn}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}"
                                         VerticalAlignment="Center"/>
                                <TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontWeight="SemiBold" Text="Signed in"/>
                            </StackPanel>
                            <TextBlock Text="{Binding SignedInAccount, StringFormat='as {0}'}"
                                       Margin="0,8,0,0" FontSize="13"/>
                            <TextBlock Text="Token saved on this PC. Auto-restored on next launch."
                                       Margin="0,6,0,0" FontSize="11"
                                       Foreground="{StaticResource SubtleForegroundBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Sign out" Command="{Binding SignOutCommand}"
                                VerticalAlignment="Center" MinWidth="120">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSignedIn}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- LIBRARY ACCESS -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="LIBRARY ACCESS"/>
                <TextBlock Style="{StaticResource SectionSubheader}"
                           Text="How SteamPhantom reads your game list. Either path works on its own — pick whichever you're more comfortable with."/>

                <Border Style="{StaticResource SettingsCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Steam64 ID"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding SteamId64, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas, Cascadia Mono"/>
                            <Button Grid.Column="1" Content="Detect"
                                    Command="{Binding DetectCommand}"
                                    Style="{StaticResource GhostButton}"
                                    Margin="10,0,0,0" Padding="16,9"/>
                        </Grid>
                        <TextBlock Style="{StaticResource FieldHelp}"
                                   Text="Auto-detected from the Steam client when it's running. Leave blank to let Library auto-detect on load."/>
                        <TextBlock Text="{Binding DetectMessage}" Margin="0,4,0,0" FontSize="11"
                                   Foreground="{StaticResource AccentBrush}"
                                   Visibility="{Binding DetectMessage,
                                                Converter={x:Static vm:StringNotEmptyToVisibilityConverter.Instance}}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCard}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Steam Web API Key"/>
                            <TextBlock Grid.Column="1" FontSize="10"
                                       Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"
                                       VerticalAlignment="Bottom" Margin="0,0,0,6"
                                       Text="recommended"/>
                        </Grid>

                        <!-- Recommendation callout -->
                        <Border Margin="0,4,0,12" Padding="14,12" CornerRadius="8"
                                Background="{StaticResource AccentSoftBrush}"
                                BorderBrush="{StaticResource AccentBrush}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE82F;"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="18"
                                           VerticalAlignment="Top" Margin="0,1,12,0"
                                           Foreground="{StaticResource AccentBrush}"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Prefer this over signing in"
                                               FontWeight="SemiBold" FontSize="12"
                                               Foreground="{StaticResource ForegroundBrush}"/>
                                    <TextBlock Margin="0,4,0,0" FontSize="11" TextWrapping="Wrap"
                                               Foreground="{StaticResource SubtleForegroundBrush}"
                                               Text="A Web API key is read-only — it can list your games but can't act on your account. You never type your password or store a session token. Revoke it any time at steamcommunity.com/dev/apikey. Strictly safer than the sign-in above; only downside is ~30 seconds of setup."/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBox Text="{Binding SteamWebApiKey, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas, Cascadia Mono"/>
                        <TextBlock Style="{StaticResource FieldHelp}" TextWrapping="Wrap"
                                   Text="Generate one at steamcommunity.com/dev/apikey (any domain name works — e.g. 'localhost'). 32-character hex string."/>
                    </StackPanel>
                </Border>

                <!-- STARTUP -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="STARTUP"/>
                <Border Style="{StaticResource SettingsCard}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Launch minimized to tray"/>
                                <TextBlock Style="{StaticResource FieldHelp}" Margin="0,0,0,0"
                                           Text="Skip showing the window on launch. The tray icon is the only thing you'll see — left-click it to open."/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource RoundCheckBox}"
                                      VerticalAlignment="Center" Margin="20,0,0,0"
                                      IsChecked="{Binding LaunchMinimized}"/>
                        </Grid>

                        <Border Margin="0,16,0,16" Height="1"
                                Background="{StaticResource BorderBrush}" Opacity="0.5"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Run at Windows startup"/>
                                <TextBlock Style="{StaticResource FieldHelp}" Margin="0,0,0,0"
                                           Text="Add SteamPhantom to your Windows login programs. Launches to tray automatically so it's there before you open Steam."/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource RoundCheckBox}"
                                      VerticalAlignment="Center" Margin="20,0,0,0"
                                      IsChecked="{Binding RunAtWindowsStartup}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- IDLING -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="IDLING"/>
                <Border Style="{StaticResource SettingsCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Auto-stop after"/>
                            <TextBlock Style="{StaticResource FieldHelp}" Margin="0,0,0,0"
                                       Text="Each idle session stops itself after this many hours. 0 disables — sessions run until you stop them or the app closes."/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBox Width="56" Padding="8,6"
                                     Text="{Binding IdleAutoStopHoursText, UpdateSourceTrigger=PropertyChanged}"
                                     HorizontalContentAlignment="Center"/>
                            <TextBlock Text="hours" Margin="8,0,0,0" VerticalAlignment="Center"
                                       Foreground="{StaticResource SubtleForegroundBrush}"
                                       FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- APPEARANCE -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="APPEARANCE"/>
                <Border Style="{StaticResource SettingsCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Theme"/>
                            <TextBlock Style="{StaticResource FieldHelp}" Margin="0,0,0,0"
                                       Text="Dark only for now — a light mode will come along with system-theme tracking."/>
                        </StackPanel>
                        <ComboBox Grid.Column="1" VerticalAlignment="Center"
                                  ItemsSource="{Binding Themes}" SelectedItem="{Binding Theme}"
                                  Width="180"/>
                    </Grid>
                </Border>

                <!-- ABOUT -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="ABOUT"/>
                <Border Style="{StaticResource SettingsCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="14" Height="14" VerticalAlignment="Center">
                                <Ellipse Fill="{StaticResource AccentBrush}" Opacity="0.35"/>
                                <Ellipse Fill="{StaticResource AccentBrush}" Width="8" Height="8"/>
                            </Grid>
                            <TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
                                       FontWeight="SemiBold" FontSize="14">
                                <Run Text="Steam"/><Run Text="Phantom" Foreground="{StaticResource AccentBrush}"/>
                                <Run Text=" · v0.1"
                                     Foreground="{StaticResource SubtleForegroundBrush}"/>
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Style="{StaticResource FieldHelp}" Margin="0,8,0,0"
                                   Text="Idle, unlock achievements, and auto-farm trading cards from one app."/>
                        <TextBlock Margin="0,8,0,0" FontSize="11"
                                   Foreground="{StaticResource SubtleForegroundBrush}">
                            <Run Text="brought to you by "/><Run Text="~NULL"
                                Foreground="{StaticResource ForegroundBrush}" FontWeight="SemiBold"/><Run Text=" · "/><Run Text="discord.gg/3x3"
                                Foreground="{StaticResource AccentBrush}"/>
                        </TextBlock>

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Click="Discord_Click" Padding="18,9">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8F2;"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Text="Join Discord" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Margin="10,0,0,0" Padding="14,8"
                                    Style="{StaticResource GhostButton}"
                                    Click="OpenSettingsFolder_Click"
                                    Content="Open settings folder"/>
                        </StackPanel>

                        <TextBlock Text="{Binding SettingsFilePath, StringFormat='Settings file: {0}'}"
                                   Margin="0,16,0,0" FontSize="11"
                                   Foreground="{StaticResource MutedForegroundBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding SettingsFilePath}"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Sticky save bar -->
        <Border Grid.Row="1" Background="{StaticResource TitleBarBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="36,14">
            <Grid MaxWidth="760" HorizontalAlignment="Left">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                           Foreground="{StaticResource SubtleForegroundBrush}" FontSize="11"
                           TextTrimming="CharacterEllipsis"/>
                <Button Grid.Column="1" Content="Save changes"
                        Command="{Binding SaveCommand}" MinWidth="160"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
