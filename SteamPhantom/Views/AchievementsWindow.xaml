<Window x:Class="SteamPhantom.Views.AchievementsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:SteamPhantom.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:AchievementsWindowViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Achievements" Width="900" Height="720"
        MinWidth="640" MinHeight="480"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource ForegroundBrush}"
        FontFamily="{StaticResource UiFontFamily}"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#15FFFFFF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1AFFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="WindowCloseButton" TargetType="Button" BasedOn="{StaticResource WindowButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootContainer">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0" Background="{StaticResource TitleBarBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="&#xED5A;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="14" VerticalAlignment="Center"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
                               FontSize="12" FontWeight="SemiBold"
                               Text="Achievements"/>
                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource SubtleForegroundBrush}"
                               Text="{Binding GameName, StringFormat=' — {0}'}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource WindowButton}" Click="Minimize_Click" Content="&#xE921;"/>
                    <Button Style="{StaticResource WindowButton}" Click="MaximizeRestore_Click">
                        <TextBlock x:Name="MaxRestoreGlyph"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="10" Text="&#xE922;"/>
                    </Button>
                    <Button Style="{StaticResource WindowCloseButton}" Click="Close_Click" Content="&#xE8BB;"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Header: game capsule + name + counts -->
        <Border Grid.Row="1" Padding="24,20,24,16"
                Background="{StaticResource BackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="#FF0A0A12" Height="93" CornerRadius="8" ClipToBounds="True">
                    <Image Source="{Binding HeaderImageUrl}" Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding GameName}" FontSize="22" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold">
                            <Run Text="{Binding UnlockedCount, Mode=OneWay}"/><Run Text=" / "/><Run Text="{Binding TotalCount, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Margin="6,0,0,0" Foreground="{StaticResource SubtleForegroundBrush}"
                                   Text="unlocked"/>
                        <TextBlock Margin="16,0,0,0" Foreground="{StaticResource SubtleForegroundBrush}"
                                   Text="•"/>
                        <TextBlock Margin="16,0,0,0">
                            <Run Foreground="{StaticResource AccentSecondaryBrush}" FontWeight="SemiBold"
                                 Text="{Binding DirtyCount, Mode=OneWay}"/><Run Text=" pending change(s)"
                                 Foreground="{StaticResource SubtleForegroundBrush}"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab strip: Achievements / Stats -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="24,4,24,14">
            <RadioButton Style="{StaticResource FilterPill}" GroupName="Tabs"
                         Content="Achievements"
                         IsChecked="{Binding ActiveTab, ConverterParameter=Achievements,
                                     Converter={x:Static vm:EnumToBooleanConverter.Instance},
                                     Mode=OneWay}"
                         Command="{Binding SetActiveTabCommand}"
                         CommandParameter="Achievements"/>
            <RadioButton Style="{StaticResource FilterPill}" GroupName="Tabs"
                         Content="Stats"
                         IsChecked="{Binding ActiveTab, ConverterParameter=Stats,
                                     Converter={x:Static vm:EnumToBooleanConverter.Instance},
                                     Mode=OneWay}"
                         Command="{Binding SetActiveTabCommand}"
                         CommandParameter="Stats"/>
        </StackPanel>

        <!-- Search + bulk actions -->
        <Grid Grid.Row="3" Margin="24,0,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <TextBox x:Name="SearchBox"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Padding="38,9,12,9"/>
                <TextBlock Text="&#xE721;"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"
                           IsHitTestVisible="False"
                           Margin="14,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left"
                           Foreground="{StaticResource SubtleForegroundBrush}"/>
                <TextBlock Text="Search achievements..."
                           IsHitTestVisible="False"
                           Margin="40,0,0,0" VerticalAlignment="Center"
                           Foreground="{StaticResource MutedForegroundBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=SearchBox, Path=Text}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <Button Grid.Column="1" Style="{StaticResource GhostButton}"
                    Margin="10,0,0,0"
                    Command="{Binding UnlockAllVisibleCommand}"
                    ToolTip="Unlock every achievement in the current view"
                    Visibility="{Binding IsOnStatsTab, Converter={x:Static vm:InverseBoolToVisibilityConverter.Instance}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE785;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text="Unlock all" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="2" Style="{StaticResource GhostButton}"
                    Margin="10,0,0,0"
                    Command="{Binding LockAllVisibleCommand}"
                    ToolTip="Lock every achievement in the current view"
                    Visibility="{Binding IsOnStatsTab, Converter={x:Static vm:InverseBoolToVisibilityConverter.Instance}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE72E;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text="Lock all" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Sort + status filter (Achievements tab only) -->
        <Grid Grid.Row="4" Margin="24,0,24,14"
              Visibility="{Binding IsOnStatsTab, Converter={x:Static vm:InverseBoolToVisibilityConverter.Instance}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Sort"
                           Foreground="{StaticResource SubtleForegroundBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                <ComboBox ItemsSource="{Binding SortOptions}"
                          SelectedItem="{Binding SelectedSort}"
                          DisplayMemberPath="Label"
                          MinWidth="170" Padding="10,6"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <RadioButton Style="{StaticResource FilterPill}" GroupName="StatusFilter"
                             Content="All"
                             IsChecked="{Binding StatusFilter, ConverterParameter=All,
                                         Converter={x:Static vm:EnumToBooleanConverter.Instance},
                                         Mode=OneWay}"
                             Command="{Binding SetStatusFilterCommand}"
                             CommandParameter="All"/>
                <RadioButton Style="{StaticResource FilterPill}" GroupName="StatusFilter"
                             Content="Unlocked"
                             IsChecked="{Binding StatusFilter, ConverterParameter=Unlocked,
                                         Converter={x:Static vm:EnumToBooleanConverter.Instance},
                                         Mode=OneWay}"
                             Command="{Binding SetStatusFilterCommand}"
                             CommandParameter="Unlocked"/>
                <RadioButton Style="{StaticResource FilterPill}" GroupName="StatusFilter"
                             Content="Locked"
                             IsChecked="{Binding StatusFilter, ConverterParameter=Locked,
                                         Converter={x:Static vm:EnumToBooleanConverter.Instance},
                                         Mode=OneWay}"
                             Command="{Binding SetStatusFilterCommand}"
                             CommandParameter="Locked"/>
                <RadioButton Style="{StaticResource FilterPill}" GroupName="StatusFilter"
                             Content="Hidden"
                             IsChecked="{Binding StatusFilter, ConverterParameter=Hidden,
                                         Converter={x:Static vm:EnumToBooleanConverter.Instance},
                                         Mode=OneWay}"
                             Command="{Binding SetStatusFilterCommand}"
                             CommandParameter="Hidden"/>
                <RadioButton Style="{StaticResource FilterPill}" GroupName="StatusFilter"
                             Content="Pending"
                             IsChecked="{Binding StatusFilter, ConverterParameter=Dirty,
                                         Converter={x:Static vm:EnumToBooleanConverter.Instance},
                                         Mode=OneWay}"
                             Command="{Binding SetStatusFilterCommand}"
                             CommandParameter="Dirty"/>
            </StackPanel>
        </Grid>

        <!-- Body: Achievements list (state-aware) -->
        <Grid Grid.Row="5" Margin="24,0,24,0"
              Visibility="{Binding IsOnStatsTab, Converter={x:Static vm:InverseBoolToVisibilityConverter.Instance}}">

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding State, ConverterParameter=Loading,
                                     Converter={x:Static vm:EnumToVisibilityConverter.Instance}}">
                <ProgressBar IsIndeterminate="True" Width="220" Height="3"
                             Background="{StaticResource SurfaceBrush}"
                             Foreground="{StaticResource AccentBrush}" BorderThickness="0"/>
                <TextBlock Margin="0,14,0,0" HorizontalAlignment="Center"
                           Foreground="{StaticResource SubtleForegroundBrush}"
                           Text="Loading achievement list..."/>
            </StackPanel>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding State, ConverterParameter=Saving,
                                     Converter={x:Static vm:EnumToVisibilityConverter.Instance}}">
                <ProgressBar IsIndeterminate="True" Width="220" Height="3"
                             Background="{StaticResource SurfaceBrush}"
                             Foreground="{StaticResource AccentBrush}" BorderThickness="0"/>
                <TextBlock Margin="0,14,0,0" HorizontalAlignment="Center"
                           Foreground="{StaticResource SubtleForegroundBrush}"
                           Text="{Binding SaveStatus}" TextWrapping="Wrap" MaxWidth="500" TextAlignment="Center"/>
            </StackPanel>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="500"
                        Visibility="{Binding State, ConverterParameter=Error,
                                     Converter={x:Static vm:EnumToVisibilityConverter.Instance}}">
                <TextBlock Text="&#xEA39;"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="40"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource DangerBrush}"/>
                <TextBlock Text="Something went wrong" FontSize="18" FontWeight="SemiBold"
                           Margin="0,12,0,0" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap" TextAlignment="Center"
                           Margin="0,8,0,0"
                           Foreground="{StaticResource SubtleForegroundBrush}"/>
            </StackPanel>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding State, ConverterParameter=Empty,
                                     Converter={x:Static vm:EnumToVisibilityConverter.Instance}}">
                <TextBlock Text="This game has no achievements."
                           Foreground="{StaticResource SubtleForegroundBrush}"/>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding State, ConverterParameter=Loaded,
                                       Converter={x:Static vm:EnumToVisibilityConverter.Instance}}">
                <ItemsControl ItemsSource="{Binding AchievementsView}" Margin="0,0,0,16">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Margin="0,0,0,8">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDirty}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid Margin="16,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Style="{StaticResource RoundCheckBox}"
                                              IsChecked="{Binding Achieved}"
                                              VerticalAlignment="Center"/>

                                    <!-- Icon: gray placeholder when missing -->
                                    <Border Grid.Column="1" Width="44" Height="44" Margin="14,0,0,0"
                                            CornerRadius="6" ClipToBounds="True"
                                            Background="#FF0A0A12"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Achieved}" Value="False">
                                                        <Setter Property="Opacity" Value="0.45"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Image Source="{Binding Icon}"
                                               Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>

                                    <StackPanel Grid.Column="2" Margin="14,0,12,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="&#xE72E;" Margin="8,0,0,0"
                                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="11" VerticalAlignment="Center"
                                                       Foreground="{StaticResource MutedForegroundBrush}"
                                                       ToolTip="Hidden achievement">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Hidden}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Text="{Binding DisplayDescription}" Margin="0,4,0,0"
                                                   FontSize="12"
                                                   Foreground="{StaticResource SubtleForegroundBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding OriginallyUnlockedAt, StringFormat='Unlocked {0:yyyy-MM-dd}'}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource SubtleForegroundBrush}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding OriginallyUnlockedAt}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Body: Stats list (state-aware) -->
        <Grid Grid.Row="5" Margin="24,0,24,0"
              Visibility="{Binding IsOnStatsTab, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}">

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding StatsState, ConverterParameter=Loading,
                                     Converter={x:Static vm:EnumToVisibilityConverter.Instance}}">
                <ProgressBar IsIndeterminate="True" Width="220" Height="3"
                             Background="{StaticResource SurfaceBrush}"
                             Foreground="{StaticResource AccentBrush}" BorderThickness="0"/>
                <TextBlock Margin="0,14,0,0" HorizontalAlignment="Center"
                           Foreground="{StaticResource SubtleForegroundBrush}"
                           Text="Loading stats..."/>
            </StackPanel>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="500"
                        Visibility="{Binding StatsState, ConverterParameter=Empty,
                                     Converter={x:Static vm:EnumToVisibilityConverter.Instance}}">
                <TextBlock Text="&#xE946;"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="40"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource SubtleForegroundBrush}"/>
                <TextBlock Text="No editable stats for this game" FontSize="16" FontWeight="SemiBold"
                           Margin="0,12,0,0" HorizontalAlignment="Center"/>
                <TextBlock TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,0"
                           Foreground="{StaticResource SubtleForegroundBrush}"
                           Text="Either the game doesn't expose user stats, or Steam hasn't cached a schema yet (try launching the game once)."/>
            </StackPanel>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="500"
                        Visibility="{Binding StatsState, ConverterParameter=Error,
                                     Converter={x:Static vm:EnumToVisibilityConverter.Instance}}">
                <TextBlock Text="&#xEA39;"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="40"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource DangerBrush}"/>
                <TextBlock Text="Couldn't load stats" FontSize="16" FontWeight="SemiBold"
                           Margin="0,12,0,0" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding StatsErrorMessage}" TextWrapping="Wrap" TextAlignment="Center"
                           Margin="0,8,0,0"
                           Foreground="{StaticResource SubtleForegroundBrush}"/>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding StatsState, ConverterParameter=Loaded,
                                       Converter={x:Static vm:EnumToVisibilityConverter.Instance}}">
                <ItemsControl ItemsSource="{Binding StatsView}" Margin="0,0,0,16">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Margin="0,0,0,8">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDirty}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid Margin="16,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Border Margin="10,0,0,0" Padding="6,2"
                                                    CornerRadius="999"
                                                    Background="{StaticResource ElevatedSurfaceBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                                <TextBlock Text="{Binding TypeLabel}" FontSize="10"
                                                           Foreground="{StaticResource SubtleForegroundBrush}"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Apiname}" Margin="0,3,0,0"
                                                   FontSize="11" FontFamily="Consolas, Cascadia Mono"
                                                   Foreground="{StaticResource MutedForegroundBrush}"/>
                                    </StackPanel>

                                    <TextBox Grid.Column="1"
                                             Text="{Binding ValueText, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalAlignment="Center"
                                             FontFamily="Consolas, Cascadia Mono"
                                             Width="140" Padding="10,7"/>

                                    <Button Grid.Column="2" Margin="8,0,0,0"
                                            Background="Transparent" Padding="10,8" MinWidth="0"
                                            ToolTip="Reset to default value"
                                            Command="{Binding DataContext.ResetStatToDefaultCommand,
                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="&#xE7A7;"
                                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="13"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Status banner (post-save outcome) -->
        <Border Grid.Row="6" Margin="24,4,24,8" Padding="14,12" CornerRadius="8">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding StatusIsError}" Value="True">
                            <Setter Property="Background" Value="#33E5484D"/>
                            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding StatusBanner}" Value="">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusBanner}" TextWrapping="Wrap"
                           FontSize="12" VerticalAlignment="Center"
                           Foreground="{StaticResource ForegroundBrush}"/>
                <Button Grid.Column="1" Command="{Binding DismissBannerCommand}"
                        Background="Transparent" Padding="8,4" Margin="12,0,0,0"
                        VerticalAlignment="Top" MinWidth="0">
                    <TextBlock Text="&#xE8BB;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="10"/>
                </Button>
            </Grid>
        </Border>

        <!-- Save bar -->
        <Border Grid.Row="7" Background="{StaticResource TitleBarBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Drip-feed is Achievements-only -->
                <CheckBox Style="{StaticResource RoundCheckBox}" IsChecked="{Binding DripFeed}"
                          VerticalAlignment="Center"
                          Visibility="{Binding IsOnStatsTab, Converter={x:Static vm:InverseBoolToVisibilityConverter.Instance}}"/>
                <StackPanel Grid.Column="0" Margin="32,0,0,0" VerticalAlignment="Center"
                            Visibility="{Binding IsOnStatsTab, Converter={x:Static vm:InverseBoolToVisibilityConverter.Instance}}">
                    <TextBlock Text="Drip-feed unlocks" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock Text="Spread changes over time so they don't all pop at once."
                               FontSize="11"
                               Foreground="{StaticResource SubtleForegroundBrush}"/>
                </StackPanel>

                <Button Grid.Column="2" Content="Apply changes"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding HasDirtyChanges}"
                        MinWidth="160"/>
            </Grid>
        </Border>
    </Grid>
</Window>
