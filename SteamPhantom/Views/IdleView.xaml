<UserControl x:Class="SteamPhantom.Views.IdleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SteamPhantom.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:IdleViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="StopButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource DangerBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,20,24,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Idle" FontSize="26" FontWeight="SemiBold"/>

        <!-- Toolbar -->
        <Grid Grid.Row="1" Margin="0,16,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}"
                         VerticalAlignment="Center"/>
                <TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
                           Foreground="{StaticResource SubtleForegroundBrush}">
                    <Run Text="{Binding Manager.Sessions.Count, Mode=OneWay}"/><Run Text=" active session(s)"/>
                </TextBlock>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="Stop all"
                    Command="{Binding StopAllCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource StopButton}">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Manager.Sessions.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <Grid Grid.Row="2">

            <!-- Empty state -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Manager.Sessions.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="&#xE916;"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="48"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource SubtleForegroundBrush}"/>
                <TextBlock Text="No active idle sessions" FontSize="18" FontWeight="SemiBold"
                           Margin="0,16,0,0" HorizontalAlignment="Center"/>
                <TextBlock TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,0"
                           Foreground="{StaticResource SubtleForegroundBrush}"
                           Text="Open the Library, hover any game, and click Start idling. Steam must be running and signed in."/>
            </StackPanel>

            <!-- Sessions list -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Manager.Sessions.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <ItemsControl ItemsSource="{Binding Manager.Sessions}" Margin="0,0,0,24">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Margin="0,0,0,10">
                                <Grid Margin="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Background="#FF0A0A12" Height="74"
                                            CornerRadius="6" ClipToBounds="True">
                                        <Image Source="{Binding HeaderImageUrl}"
                                               Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="16,0,16,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="14"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <Ellipse Width="7" Height="7" Fill="{StaticResource AccentBrush}"
                                                     VerticalAlignment="Center"/>
                                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       Text="In-game"/>
                                            <TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
                                                       FontFamily="Consolas, Cascadia Mono"
                                                       Foreground="{StaticResource SubtleForegroundBrush}"
                                                       Text="{Binding ElapsedDisplay}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Button Grid.Column="2" Style="{StaticResource StopButton}"
                                            VerticalAlignment="Center"
                                            Content="Stop"
                                            Command="{Binding DataContext.StopCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </Grid>
    </Grid>
</UserControl>
