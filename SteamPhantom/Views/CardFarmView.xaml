<UserControl x:Class="SteamPhantom.Views.CardFarmView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SteamPhantom.ViewModels"
             xmlns:models="clr-namespace:SteamPhantom.Models"
             d:DataContext="{d:DesignInstance Type=vm:CardFarmViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="ActiveCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="232"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,20,24,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header + counts -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Card farming" FontSize="26" FontWeight="SemiBold"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom"
                        HorizontalAlignment="Right" Margin="0,0,0,4">
                <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}"
                         VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Opacity" Value="0.25"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <Setter Property="Opacity" Value="1"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock VerticalAlignment="Center" Margin="10,0,0,0"
                           Foreground="{StaticResource SubtleForegroundBrush}">
                    <Run Text="{Binding ActiveCount, Mode=OneWay}"/><Run Text=" running · "/><Run Text="{Binding QueuedCount, Mode=OneWay}"/><Run Text=" queued · "/><Run Text="{Binding DoneCount, Mode=OneWay}"/><Run Text=" done"/>
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- Controls -->
        <Grid Grid.Row="1" Margin="0,18,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Padding="22,9" MinWidth="120"
                    Command="{Binding StartCommand}"
                    IsEnabled="{Binding CanStart}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE768;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text="Start" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="1" Style="{StaticResource GhostButton}" Margin="10,0,0,0"
                    Command="{Binding PauseCommand}" IsEnabled="{Binding CanPause}"
                    Content="Pause"/>
            <Button Grid.Column="2" Style="{StaticResource GhostButton}" Margin="10,0,0,0"
                    Command="{Binding StopCommand}" IsEnabled="{Binding CanStop}"
                    Content="Stop"/>

            <!-- Inline settings -->
            <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button Style="{StaticResource GhostButton}" Padding="14,8" Margin="0,0,16,0"
                        Command="{Binding RefillQueueCommand}"
                        ToolTip="Pick more random games and append to the queue">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="Refill queue" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <TextBlock Text="Pick" Foreground="{StaticResource SubtleForegroundBrush}"
                           VerticalAlignment="Center" FontSize="11" Margin="0,0,6,0"/>
                <TextBox Width="48" Padding="8,6"
                         Text="{Binding QueueSizeText, UpdateSourceTrigger=PropertyChanged}"
                         HorizontalContentAlignment="Center"/>
                <TextBlock Text="games · concurrent" Foreground="{StaticResource SubtleForegroundBrush}"
                           VerticalAlignment="Center" FontSize="11" Margin="6,0,6,0"/>
                <TextBox Width="48" Padding="8,6"
                         Text="{Binding MaxConcurrentText, UpdateSourceTrigger=PropertyChanged}"
                         HorizontalContentAlignment="Center"/>
                <TextBlock Text="· rotate" Foreground="{StaticResource SubtleForegroundBrush}"
                           VerticalAlignment="Center" FontSize="11" Margin="6,0,6,0"/>
                <TextBox Width="48" Padding="8,6"
                         Text="{Binding RotationMinutesText, UpdateSourceTrigger=PropertyChanged}"
                         HorizontalContentAlignment="Center"/>
                <TextBlock Text="min" Margin="6,0,0,0" VerticalAlignment="Center"
                           Foreground="{StaticResource SubtleForegroundBrush}" FontSize="11"/>
            </StackPanel>
        </Grid>

        <!-- Body: empty state OR sections -->
        <Grid Grid.Row="2">

            <!-- Empty state: auto-farm CTA -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="480">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Manager.Entries.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="&#xEE94;"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="48"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text="Auto-farm trading cards" FontSize="20" FontWeight="SemiBold"
                           Margin="0,16,0,0" HorizontalAlignment="Center"/>
                <TextBlock TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,24"
                           Foreground="{StaticResource SubtleForegroundBrush}"
                           Text="Picks random games from your library and rotates the pool every few minutes. Anything already running in the Idle tab is skipped automatically."/>
                <Button Padding="22,11" MinWidth="220" HorizontalAlignment="Center"
                        Command="{Binding AutoFarmCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE768;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="Start auto-farming" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="{Binding AutoFillStatus}" Margin="0,14,0,0"
                           HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                           FontSize="11"
                           Foreground="{StaticResource SubtleForegroundBrush}"
                           Visibility="{Binding AutoFillStatus,
                                        Converter={x:Static vm:StringNotEmptyToVisibilityConverter.Instance}}"/>
                <TextBlock TextWrapping="Wrap" TextAlignment="Center" Margin="0,28,0,0"
                           FontSize="11"
                           Foreground="{StaticResource MutedForegroundBrush}"
                           Text="Want to pick specific games instead? Library → multi-select → Add to card farm."/>
            </StackPanel>

            <!-- List of sections -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Manager.Entries.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel Margin="0,0,0,24">

                    <!-- ACTIVE -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveCount}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Active" FontWeight="SemiBold" Margin="0,0,0,8"
                                   Foreground="{StaticResource SubtleForegroundBrush}"/>
                        <ItemsControl ItemsSource="{Binding Manager.Entries}" Margin="-6,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:CardFarmEntry}">
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource ActiveCard}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Active">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <Border Background="#FF0A0A12" Height="109">
                                                <Image Source="{Binding HeaderImageUrl}"
                                                       Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Border>
                                            <StackPanel Margin="14,12,14,14">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding Name}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                    <Ellipse Width="6" Height="6"
                                                             Fill="{StaticResource AccentBrush}"
                                                             VerticalAlignment="Center"/>
                                                    <TextBlock Margin="8,0,0,0" VerticalAlignment="Center"
                                                               FontFamily="Consolas, Cascadia Mono"
                                                               FontSize="11"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               Text="{Binding ElapsedDisplay}"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding CardsDisplay}"
                                                           Margin="0,4,0,0" FontSize="11"
                                                           Foreground="{StaticResource SubtleForegroundBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Session aggregate: card drops earned + remaining across the queue -->
                    <Border Margin="0,18,0,0" Padding="18,14" CornerRadius="10"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveCount}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock FontSize="12">
                                    <Run Text="Session · "/><Run FontWeight="SemiBold"
                                        Foreground="{StaticResource AccentBrush}"
                                        Text="{Binding TotalEarnedThisSession, Mode=OneWay, StringFormat='+{0}'}"/><Run
                                        Text=" card drop(s) earned"/>
                                </TextBlock>
                                <TextBlock FontSize="11" Margin="0,4,0,0"
                                           Foreground="{StaticResource SubtleForegroundBrush}">
                                    <Run Text="{Binding TotalDropsRemaining, Mode=OneWay}"/><Run Text=" drops remaining across the queue"/>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource AccentBrush}"
                                         VerticalAlignment="Center" Opacity="0.6"/>
                                <TextBlock Margin="8,0,0,0" VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedForegroundBrush}"
                                           Text="auto-refreshing every 2 min"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- QUEUE -->
                    <StackPanel Margin="0,18,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding QueuedCount}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Queue" FontWeight="SemiBold" Margin="0,0,0,8"
                                   Foreground="{StaticResource SubtleForegroundBrush}"/>
                        <ItemsControl ItemsSource="{Binding Manager.Entries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:CardFarmEntry}">
                                    <Border Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1" CornerRadius="8"
                                            Margin="0,0,0,8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Queued">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </Style>
                                        </Border.Style>
                                        <Grid Margin="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Background="#FF0A0A12" Height="56"
                                                    CornerRadius="6" ClipToBounds="True">
                                                <Image Source="{Binding HeaderImageUrl}"
                                                       Stretch="UniformToFill"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                        Margin="14,0,12,0">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding CardsDisplay}" Margin="0,4,0,0"
                                                           FontSize="11"
                                                           Foreground="{StaticResource SubtleForegroundBrush}"/>
                                            </StackPanel>
                                            <Button Grid.Column="2" Style="{StaticResource GhostButton}"
                                                    VerticalAlignment="Center"
                                                    Padding="10,6"
                                                    Command="{Binding DataContext.RemoveEntryCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Text="&#xE74D;"
                                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                           FontSize="11"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- DONE / SKIPPED -->
                    <StackPanel Margin="0,18,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DoneCount}"    Value="0"/>
                                            <Condition Binding="{Binding SkippedCount}" Value="0"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Finished" FontWeight="SemiBold"
                                       Foreground="{StaticResource SubtleForegroundBrush}"/>
                            <Button Grid.Column="1" Style="{StaticResource GhostButton}" Padding="10,4"
                                    Content="Clear" Command="{Binding ClearDoneCommand}"/>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding Manager.Entries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:CardFarmEntry}">
                                    <Border Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1" CornerRadius="8"
                                            Padding="12" Margin="0,0,0,6">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Done">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Skipped">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock VerticalAlignment="Center"
                                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="14" Foreground="{StaticResource MutedForegroundBrush}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="&#xE73E;"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Skipped">
                                                                <Setter Property="Text" Value="&#xE783;"/>
                                                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <StackPanel Grid.Column="1" Margin="12,0,12,0">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding StatusMessage}"
                                                           Foreground="{StaticResource SubtleForegroundBrush}"
                                                           FontSize="11" Margin="0,2,0,0"
                                                           Visibility="{Binding StatusMessage,
                                                                        Converter={x:Static vm:StringNotEmptyToVisibilityConverter.Instance}}"/>
                                            </StackPanel>
                                            <Button Grid.Column="2" Style="{StaticResource GhostButton}"
                                                    VerticalAlignment="Center" Padding="10,4"
                                                    Command="{Binding DataContext.RemoveEntryCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Text="&#xE74D;"
                                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                           FontSize="11"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
