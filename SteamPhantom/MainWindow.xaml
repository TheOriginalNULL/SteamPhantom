<Window x:Class="SteamPhantom.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:SteamPhantom.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:ShellViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SteamPhantom" Height="680" Width="1100"
        MinWidth="720" MinHeight="480"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource ForegroundBrush}"
        FontFamily="{StaticResource UiFontFamily}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False">

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RefreshLibraryCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="R" Command="{Binding RefreshLibraryCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="D1" Command="{Binding NavigateCommand}" CommandParameter="Library"/>
        <KeyBinding Modifiers="Ctrl" Key="D2" Command="{Binding NavigateCommand}" CommandParameter="Idle"/>
        <KeyBinding Modifiers="Ctrl" Key="D3" Command="{Binding NavigateCommand}" CommandParameter="Cards"/>
        <KeyBinding Modifiers="Ctrl" Key="D4" Command="{Binding NavigateCommand}" CommandParameter="Settings"/>
    </Window.InputBindings>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid x:Name="RootContainer">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Border Grid.Row="0"
                Background="{StaticResource TitleBarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Brand mark + title (drag region) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center" Margin="16,0,0,0">
                    <Image x:Name="BrandIcon" Width="20" Height="20" VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource ForegroundBrush}">
                        <Run Text="Steam"/><Run Text="Phantom" Foreground="{StaticResource AccentBrush}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Credit (centered, single line, clickable) -->
                <TextBlock Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                           shell:WindowChrome.IsHitTestVisibleInChrome="True"
                           Cursor="Hand" MouseLeftButtonUp="Discord_Click"
                           FontSize="11"
                           Foreground="{StaticResource MutedForegroundBrush}"
                           ToolTip="Join our Discord">
                    <Run Text="brought to you by "/><Run Text="~NULL"
                        Foreground="{StaticResource ForegroundBrush}" FontWeight="SemiBold"/><Run Text=" · "/><Run Text="discord.gg/3x3"
                        Foreground="{StaticResource AccentBrush}"/>
                </TextBlock>

                <!-- Caption buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource WindowButton}"
                            Click="Minimize_Click"
                            ToolTip="Minimize"
                            Content="&#xE921;"/>
                    <Button Style="{StaticResource WindowButton}"
                            Click="MaximizeRestore_Click"
                            ToolTip="Maximize">
                        <TextBlock x:Name="MaxRestoreGlyph"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="10"
                                   Text="&#xE922;"/>
                    </Button>
                    <Button Style="{StaticResource WindowCloseButton}"
                            Click="Close_Click"
                            ToolTip="Close"
                            Content="&#xE8BB;"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Body: sidebar + content host -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Update banner — only shown when the checker found a newer version -->
            <Border Grid.Row="0" Grid.ColumnSpan="2"
                    Padding="20,10" BorderThickness="0,0,0,1"
                    Background="{StaticResource AccentSoftBrush}"
                    BorderBrush="{StaticResource AccentBrush}"
                    Visibility="{Binding HasUpdate, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="&#xE896;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource AccentBrush}"/>
                    <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock FontWeight="SemiBold" FontSize="12">
                            <Run Text="New version available · "/><Run Text="{Binding UpdateVersion, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="{Binding UpdateReleaseNotes}" FontSize="11"
                                   Foreground="{StaticResource SubtleForegroundBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   Visibility="{Binding UpdateReleaseNotes,
                                                Converter={x:Static vm:StringNotEmptyToVisibilityConverter.Instance}}"/>
                    </StackPanel>
                    <Button Grid.Column="2" Margin="14,0,0,0" Padding="14,6"
                            Command="{Binding OpenDownloadCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE896;"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock Text="Download" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="3" Margin="6,0,0,0" Padding="8,4"
                            Background="Transparent" MinWidth="0"
                            ToolTip="Dismiss until next launch"
                            Command="{Binding DismissUpdateCommand}">
                        <TextBlock Text="&#xE8BB;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="10"/>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Footer: thank-you + system status -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="20,0,20,16">
                        <Border Margin="0,0,0,12" Height="1"
                                Background="{StaticResource BorderBrush}" Opacity="0.6"/>
                        <TextBlock TextAlignment="Center" TextWrapping="Wrap"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}"
                                   Text="Thanks for trusting me and my software :3"/>
                        <TextBlock Margin="0,12,0,0" TextAlignment="Center"
                                   FontSize="10" TextWrapping="Wrap"
                                   Foreground="{StaticResource MutedForegroundBrush}"
                                   Text="Steam must be running and signed in."/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Top" Margin="0,12,0,0">
                        <RadioButton Style="{StaticResource NavButton}"
                                     GroupName="Nav"
                                     Tag="&#xE82D;"
                                     ToolTip="Your owned games (Ctrl+1)"
                                     IsChecked="{Binding ActiveSection, ConverterParameter=Library,
                                                 Converter={x:Static vm:EnumToBooleanConverter.Instance},
                                                 Mode=OneWay}"
                                     Command="{Binding NavigateCommand}" CommandParameter="Library"
                                     Content="Library"/>
                        <RadioButton Style="{StaticResource NavButton}"
                                     GroupName="Nav"
                                     Tag="&#xE916;"
                                     ToolTip="Active idle sessions (Ctrl+2)"
                                     IsChecked="{Binding ActiveSection, ConverterParameter=Idle,
                                                 Converter={x:Static vm:EnumToBooleanConverter.Instance},
                                                 Mode=OneWay}"
                                     Command="{Binding NavigateCommand}" CommandParameter="Idle"
                                     Content="Idle"/>
                        <RadioButton Style="{StaticResource NavButton}"
                                     GroupName="Nav"
                                     Tag="&#xEE94;"
                                     ToolTip="Auto-farm trading cards (Ctrl+3)"
                                     IsChecked="{Binding ActiveSection, ConverterParameter=Cards,
                                                 Converter={x:Static vm:EnumToBooleanConverter.Instance},
                                                 Mode=OneWay}"
                                     Command="{Binding NavigateCommand}" CommandParameter="Cards"
                                     Content="Cards"/>
                        <RadioButton Style="{StaticResource NavButton}"
                                     GroupName="Nav"
                                     Tag="&#xE713;"
                                     ToolTip="Account, library access, appearance (Ctrl+4)"
                                     IsChecked="{Binding ActiveSection, ConverterParameter=Settings,
                                                 Converter={x:Static vm:EnumToBooleanConverter.Instance},
                                                 Mode=OneWay}"
                                     Command="{Binding NavigateCommand}" CommandParameter="Settings"
                                     Content="Settings"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <ContentControl Grid.Column="1" Content="{Binding CurrentPage}"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
