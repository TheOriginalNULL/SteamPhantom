<UserControl x:Class="SteamPhantom.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SteamPhantom.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:LibraryViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>

        <Style x:Key="GameCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="232"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="ClipToBounds" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ElevatedSurfaceBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                </Trigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Selection checkbox in card corner: visible on hover or when selected -->
        <Style x:Key="CardSelectCheckBox" TargetType="CheckBox" BasedOn="{StaticResource RoundCheckBox}">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid Margin="24,20,24,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Library" FontSize="26" FontWeight="SemiBold"/>

        <Grid Grid.Row="1" Margin="0,16,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MaxWidth="380"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <TextBox x:Name="SearchBox"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Padding="38,9,12,9"/>
                <TextBlock Text="&#xE721;"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"
                           IsHitTestVisible="False"
                           Margin="14,0,0,0"
                           VerticalAlignment="Center" HorizontalAlignment="Left"
                           Foreground="{StaticResource SubtleForegroundBrush}"/>
                <TextBlock Text="Search games..."
                           IsHitTestVisible="False"
                           Margin="40,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedForegroundBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=SearchBox, Path=Text}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <TextBlock Grid.Column="1" Margin="16,0,0,0"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource SubtleForegroundBrush}"
                       Visibility="{Binding State, ConverterParameter=Loaded,
                                    Converter={x:Static vm:EnumToVisibilityConverter.Instance}}">
                <Run Text="{Binding VisibleCount, Mode=OneWay}"/><Run Text=" of "/><Run Text="{Binding Games.Count, Mode=OneWay}"/><Run Text=" games"/>
            </TextBlock>

            <Button Grid.Column="2" Command="{Binding RefreshCommand}"
                    Padding="16,9" MinWidth="0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE72C;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text="Refresh" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="2">

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="500"
                        Visibility="{Binding State, ConverterParameter=NeedsSetup,
                                     Converter={x:Static vm:EnumToVisibilityConverter.Instance}}">
                <TextBlock Text="&#xE77B;"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="48"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text="Sign in to load your library" FontSize="20" FontWeight="SemiBold"
                           Margin="0,16,0,0" HorizontalAlignment="Center"/>
                <TextBlock TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,24"
                           Foreground="{StaticResource SubtleForegroundBrush}"
                           Text="Sign in with your Steam username + password. Your credentials go directly to Steam and never leave this machine. No Web API key needed."/>
                <Button Content="Sign in to Steam"
                        Command="{Binding SignInCommand}"
                        Padding="22,10" MinWidth="180"
                        HorizontalAlignment="Center"/>

                <!-- Silent-login feedback (only when there's a saved token) -->
                <Border Margin="0,20,0,0" Padding="14,10" CornerRadius="8"
                        Visibility="{Binding SilentLoginMessage,
                                     Converter={x:Static vm:StringNotEmptyToVisibilityConverter.Instance}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SilentLoginIsError}" Value="True">
                                    <Setter Property="Background" Value="#33E5484D"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding SilentLoginMessage}" TextWrapping="Wrap"
                               TextAlignment="Center" FontSize="11"
                               Foreground="{StaticResource ForegroundBrush}"/>
                </Border>

                <TextBlock TextWrapping="Wrap" TextAlignment="Center" Margin="0,16,0,0"
                           Foreground="{StaticResource MutedForegroundBrush}" FontSize="11"
                           Text="Or paste a Steam Web API key in Settings as an alternative."/>
            </StackPanel>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding State, ConverterParameter=Loading,
                                     Converter={x:Static vm:EnumToVisibilityConverter.Instance}}">
                <ProgressBar IsIndeterminate="True" Width="220" Height="3"
                             Background="{StaticResource SurfaceBrush}"
                             Foreground="{StaticResource AccentBrush}"
                             BorderThickness="0"/>
                <TextBlock Text="Fetching your library..." Margin="0,14,0,0"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource SubtleForegroundBrush}"/>
            </StackPanel>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="480"
                        Visibility="{Binding State, ConverterParameter=Error,
                                     Converter={x:Static vm:EnumToVisibilityConverter.Instance}}">
                <TextBlock Text="&#xEA39;"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="40"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource DangerBrush}"/>
                <TextBlock Text="Couldn't load library" FontSize="18" FontWeight="SemiBold"
                           Margin="0,12,0,0" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap" TextAlignment="Center"
                           Margin="0,8,0,16"
                           Foreground="{StaticResource SubtleForegroundBrush}"/>
                <Button Content="Try again" Command="{Binding RefreshCommand}"
                        HorizontalAlignment="Center" MinWidth="120"/>
            </StackPanel>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding State, ConverterParameter=Empty,
                                     Converter={x:Static vm:EnumToVisibilityConverter.Instance}}">
                <TextBlock Text="No games on this account." FontSize="14"
                           Foreground="{StaticResource SubtleForegroundBrush}"/>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding State, ConverterParameter=Loaded,
                                       Converter={x:Static vm:EnumToVisibilityConverter.Instance}}">
                <ItemsControl ItemsSource="{Binding GamesView}" Margin="-6,0,-6,24">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="Card" Style="{StaticResource GameCard}">
                                <Grid>
                                    <StackPanel>
                                        <Border Background="#FF0A0A12" Height="109">
                                            <Image Source="{Binding HeaderImageUrl}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>
                                        <StackPanel Margin="14,12,14,14">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Name}"/>
                                            <TextBlock Text="{Binding PlaytimeDisplay}"
                                                       Margin="0,4,0,0"
                                                       FontSize="11"
                                                       Foreground="{StaticResource SubtleForegroundBrush}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Selection checkbox: top-right corner, visible on hover or when selected -->
                                    <CheckBox x:Name="SelectCheck"
                                              IsChecked="{Binding IsSelected}"
                                              Style="{StaticResource CardSelectCheckBox}"
                                              VerticalAlignment="Top" HorizontalAlignment="Right"
                                              Margin="10" Panel.ZIndex="2"/>

                                    <!-- Hover overlay: appears on mouse over the card -->
                                    <Border x:Name="Overlay"
                                            Background="#D8000000"
                                            CornerRadius="10"
                                            Opacity="0">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Button Command="{Binding DataContext.StartIdleCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="20,9" MinWidth="160">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE768;"
                                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                               FontSize="13" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Start idling" Margin="8,0,0,0"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Command="{Binding DataContext.OpenAchievementsCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="0,10,0,0"
                                                    Padding="20,9" MinWidth="160"
                                                    Background="Transparent">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xED5A;"
                                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                               FontSize="13" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Achievements" Margin="8,0,0,0"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <Trigger SourceName="Card" Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Overlay" Property="Opacity" Value="1"/>
                                    <Setter TargetName="SelectCheck" Property="Visibility" Value="Visible"/>
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Multi-select action bar: appears when any cards are selected -->
            <Border VerticalAlignment="Bottom" HorizontalAlignment="Center"
                    Margin="0,0,0,16" Padding="20,12,12,12" CornerRadius="14"
                    Background="{StaticResource ElevatedSurfaceBrush}"
                    BorderBrush="{StaticResource AccentBrush}" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedCount}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}"
                             VerticalAlignment="Center"/>
                    <TextBlock VerticalAlignment="Center" Margin="10,0,0,0">
                        <Run Text="{Binding SelectedCount, Mode=OneWay}"/><Run Text=" selected"/>
                    </TextBlock>
                    <Button Margin="20,0,0,0" Padding="18,8"
                            Command="{Binding StartIdleSelectedCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE768;"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="Start idling" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Margin="8,0,0,0" Padding="14,8"
                            Style="{StaticResource GhostButton}"
                            Command="{Binding AddSelectedToCardFarmCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xEE94;"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="Add to card farm" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Margin="8,0,0,0" Padding="14,8" Background="Transparent"
                            Command="{Binding ClearSelectionCommand}"
                            Content="Clear"/>
                </StackPanel>
            </Border>

            <!-- Notification toast -->
            <Border VerticalAlignment="Bottom" HorizontalAlignment="Right"
                    Margin="0,0,16,16" Padding="18,12" CornerRadius="10"
                    MaxWidth="460">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Notification}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding NotificationIsError}" Value="True">
                                <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding Notification}" Foreground="White"
                           TextWrapping="Wrap"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
