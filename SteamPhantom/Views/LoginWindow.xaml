<Window x:Class="SteamPhantom.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:SteamPhantom.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:LoginWindowViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Sign in to Steam" Width="440" Height="540"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource ForegroundBrush}"
        FontFamily="{StaticResource UiFontFamily}"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="False">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="WindowButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1AFFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="WindowCloseButton" TargetType="Button" BasedOn="{StaticResource WindowButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootContainer">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0" Background="{StaticResource TitleBarBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="16,0,0,0">
                    <Grid Width="14" Height="14">
                        <Ellipse Fill="{StaticResource AccentBrush}" Opacity="0.35"/>
                        <Ellipse Fill="{StaticResource AccentBrush}" Width="8" Height="8"/>
                    </Grid>
                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
                               FontSize="12" FontWeight="SemiBold"
                               Text="Sign in to Steam"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource WindowCloseButton}" Click="Close_Click"
                            Content="&#xE8BB;"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1" Margin="40,30,40,30">

            <!-- Credentials view -->
            <StackPanel>
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Stage}" Value="Credentials">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <TextBlock Text="Sign in" FontSize="24" FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,28"
                           Foreground="{StaticResource SubtleForegroundBrush}"
                           Text="Your credentials are sent directly to Steam and never leave this machine."/>

                <TextBlock Text="Steam username" Margin="0,0,0,4"
                           Foreground="{StaticResource SubtleForegroundBrush}" FontSize="12"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Password" Margin="0,16,0,4"
                           Foreground="{StaticResource SubtleForegroundBrush}" FontSize="12"/>
                <PasswordBox x:Name="PasswordBox" PasswordChanged="PasswordBox_PasswordChanged"
                             Padding="12,9"
                             Background="{StaticResource SurfaceBrush}"
                             Foreground="{StaticResource ForegroundBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             CaretBrush="{StaticResource AccentBrush}"
                             FontFamily="Consolas, Cascadia Mono"
                             BorderThickness="1"/>

                <Button Margin="0,28,0,0"
                        Content="Sign in"
                        Command="{Binding SignInCommand}"
                        IsDefault="True"/>

                <TextBlock Text="{Binding StatusMessage}" Margin="0,16,0,0"
                           TextWrapping="Wrap" TextAlignment="Center"
                           Foreground="{StaticResource DangerBrush}" FontSize="12"
                           Visibility="{Binding StatusMessage,
                                        Converter={x:Static vm:StringNotEmptyToVisibilityConverter.Instance}}"/>
            </StackPanel>

            <!-- Connecting view -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Stage}" Value="Connecting">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <ProgressBar IsIndeterminate="True" Width="220" Height="3"
                             Background="{StaticResource SurfaceBrush}"
                             Foreground="{StaticResource AccentBrush}" BorderThickness="0"/>
                <TextBlock Text="{Binding StatusMessage}" Margin="0,16,0,0"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource SubtleForegroundBrush}"/>
            </StackPanel>

            <!-- Code view (email or mobile authenticator code) -->
            <StackPanel>
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Stage}" Value="Code">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <TextBlock Text="&#xE730;"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="40"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text="Steam Guard" FontSize="20" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,12,0,8"/>
                <TextBlock Text="{Binding CodePrompt}" TextWrapping="Wrap" TextAlignment="Center"
                           Foreground="{StaticResource SubtleForegroundBrush}" Margin="0,0,0,24"/>

                <TextBox Text="{Binding CodeInput, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="Consolas, Cascadia Mono" FontSize="20"
                         HorizontalContentAlignment="Center"
                         Padding="0,12" MaxLength="10"/>

                <Button Margin="0,24,0,0" Content="Submit"
                        Command="{Binding SubmitCodeCommand}" IsDefault="True"/>
            </StackPanel>

            <!-- Mobile confirmation view -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="320">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Stage}" Value="MobileConfirm">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <TextBlock Text="&#xE8EA;"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="40"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text="Approve on phone" FontSize="20" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,12,0,8"/>
                <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                           Foreground="{StaticResource SubtleForegroundBrush}"
                           Text="Open the Steam mobile app and tap Approve. We'll continue automatically."/>
                <ProgressBar IsIndeterminate="True" Width="180" Height="3" Margin="0,24,0,0"
                             Background="{StaticResource SurfaceBrush}"
                             Foreground="{StaticResource AccentBrush}" BorderThickness="0"/>
            </StackPanel>

        </Grid>
    </Grid>
</Window>
